{
  "appId": "com.ertan.bedlisiumai",
  "appName": "Bedlisium AI",
  "webDir": "www",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "backgroundColor": "#04070f",
      "showSpinner": false
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#04070f",
    "minWebViewVersion": 60,
    "webContentsDebuggingEnabled": true
  }
}
